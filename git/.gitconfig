[user]
  name = Fergus Ruston
  email = fergus.ruston@gmail.com

[core]
  editor = nvim
  excludesfile = ~/.gitignore
  pager = delta

[rerere]
  enabled = true

[fetch]
  prune = true

[diff]
  algorithm = histogram
  colorMoved = default

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[submodule]
  recurse = true

[status]
  showStash = true

[init]
  defaultBranch = main

[commit]
  verbose = true

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  line-numbers = true
  syntax-theme = Nord

[merge]
  conflictstyle = diff3

[branch]
  sort = -committerdate

[credential]
  helper = /usr/local/share/gcm-core/git-credential-manager

[alias]
  undo = reset HEAD^

[include]
  path = ~/.gitconfig-local
