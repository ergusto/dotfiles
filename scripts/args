#!/usr/bin/env bash

dispatch() {
  local cmd="${1:-install}"
  [ $# -gt 0 ] && shift

  case "$cmd" in
    install)       cmd_install "$@" ;;
    stow)          cmd_stow "$@" ;;
    pull)          cmd_pull "$@" ;;
    doctor)        cmd_doctor "$@" ;;
    help|-h|--help) cmd_help "$@" ;;
    --version)     print_version ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo "" >&2
      top_usage >&2
      exit 1
      ;;
  esac
}

top_usage() {
  cat <<EOF
Usage: dotfiles <command> [options]

Commands:
  install [opts]     First-run setup (brew + stow). Interactive by default.
  stow <action>      stow update|remove [packages...]
  pull               git pull --recurse-submodules in \$DOTFILES.
  doctor             Run diagnostic checks.
  help [command]     Show this help or per-command help.
  --version          Show dotfiles git sha.

With no command, runs 'install' interactively.
EOF
}

print_version() {
  local sha
  sha=$(git -C "$DOTFILES" rev-parse --short HEAD 2>/dev/null)
  echo "dotfiles ${sha:-unknown}"
}
